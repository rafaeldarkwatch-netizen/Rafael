{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (income or expense)",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner UID" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number", "description": "Transaction amount" },
        "category": { "type": "string", "description": "Transaction category" },
        "description": { "type": "string", "description": "Short description" },
        "date": { "type": "string", "format": "date-time", "description": "Date of transaction" },
        "receiptUrl": { "type": "string", "format": "uri", "description": "Optional receipt image URL" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "category", "description", "date", "createdAt"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A financial goal",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner UID" },
        "title": { "type": "string", "description": "Goal title" },
        "targetAmount": { "type": "number", "description": "Target amount to reach" },
        "currentAmount": { "type": "number", "description": "Current saved amount" },
        "deadline": { "type": "string", "format": "date-time", "description": "Optional deadline" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "targetAmount", "currentAmount", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Financial transactions"
    },
    "/goals/{goalId}": {
      "schema": { "$ref": "#/entities/Goal" },
      "description": "Financial goals"
    }
  }
}
